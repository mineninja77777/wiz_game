digraph G {
    graph [rankdir=TB, ranksep=0.5, layout=dot, clusterrank="local"];
    subgraph "cluster_G" {

        graph [style="filled,rounded", fillcolor="#80808018", label=""];
        "test" [label="test\n(test.py)", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="0", tooltip="test\ntest.py"];
        subgraph "cluster_engine" {

            graph [style="filled,rounded", fillcolor="#80808018", label="engine"];
            "engine__action" [label="action\n(module in engine)", style="filled", fillcolor="#e5feccb2", fontcolor="#000000", group="1", tooltip="engine.action\nmodule in engine"];
            "engine__base" [label="base\n(module in engine)", style="filled", fillcolor="#e5feccb2", fontcolor="#000000", group="1", tooltip="engine.base\nmodule in engine"];
            "engine__encounter_manager" [label="encounter_manager\n(module in engine)", style="filled", fillcolor="#e5feccb2", fontcolor="#000000", group="1", tooltip="engine.encounter_manager\nmodule in engine"];
            "engine__entity" [label="entity\n(module in engine)", style="filled", fillcolor="#e5feccb2", fontcolor="#000000", group="1", tooltip="engine.entity\nmodule in engine"];
            "engine__game_manager" [label="game_manager\n(module in engine)", style="filled", fillcolor="#e5feccb2", fontcolor="#000000", group="1", tooltip="engine.game_manager\nmodule in engine"];
        }
        subgraph "cluster_instances" {

            graph [style="filled,rounded", fillcolor="#80808018", label="instances"];
            "instances__effects" [label="effects\n(module in instances)", style="filled", fillcolor="#ccfefeb2", fontcolor="#000000", group="2", tooltip="instances.effects\nmodule in instances"];
            "instances__entities" [label="entities\n(module in instances)", style="filled", fillcolor="#ccfefeb2", fontcolor="#000000", group="2", tooltip="instances.entities\nmodule in instances"];
            "instances__others" [label="others\n(module in instances)", style="filled", fillcolor="#ccfefeb2", fontcolor="#000000", group="2", tooltip="instances.others\nmodule in instances"];
            "instances__spells" [label="spells\n(module in instances)", style="filled", fillcolor="#ccfefeb2", fontcolor="#000000", group="2", tooltip="instances.spells\nmodule in instances"];
            "instances__weapons" [label="weapons\n(module in instances)", style="filled", fillcolor="#ccfefeb2", fontcolor="#000000", group="2", tooltip="instances.weapons\nmodule in instances"];
        }
    }
        "engine__action" -> "engine__base" [style="solid",  color="#000000"];
        "engine__encounter_manager" -> "engine__action" [style="solid",  color="#000000"];
        "engine__encounter_manager" -> "engine__base" [style="solid",  color="#000000"];
        "engine__entity" -> "engine__action" [style="solid",  color="#000000"];
        "engine__entity" -> "engine__base" [style="solid",  color="#000000"];
        "engine__entity" -> "engine__encounter_manager" [style="solid",  color="#000000"];
        "engine__game_manager" -> "engine__action" [style="solid",  color="#000000"];
        "engine__game_manager" -> "engine__base" [style="solid",  color="#000000"];
        "engine__game_manager" -> "engine__encounter_manager" [style="solid",  color="#000000"];
        "engine__game_manager" -> "engine__entity" [style="solid",  color="#000000"];
        "instances__effects" -> "engine__action" [style="solid",  color="#000000"];
        "instances__effects" -> "engine__base" [style="solid",  color="#000000"];
        "instances__effects" -> "engine__encounter_manager" [style="solid",  color="#000000"];
        "instances__effects" -> "engine__entity" [style="solid",  color="#000000"];
        "instances__entities" -> "engine__action" [style="solid",  color="#000000"];
        "instances__entities" -> "engine__base" [style="solid",  color="#000000"];
        "instances__entities" -> "engine__encounter_manager" [style="solid",  color="#000000"];
        "instances__entities" -> "engine__entity" [style="solid",  color="#000000"];
        "instances__entities" -> "instances__effects" [style="solid",  color="#000000"];
        "instances__entities" -> "instances__others" [style="solid",  color="#000000"];
        "instances__entities" -> "instances__spells" [style="solid",  color="#000000"];
        "instances__entities" -> "instances__weapons" [style="solid",  color="#000000"];
        "instances__others" -> "engine__action" [style="solid",  color="#000000"];
        "instances__others" -> "engine__base" [style="solid",  color="#000000"];
        "instances__others" -> "engine__entity" [style="solid",  color="#000000"];
        "instances__others" -> "instances__effects" [style="solid",  color="#000000"];
        "instances__spells" -> "engine__action" [style="solid",  color="#000000"];
        "instances__spells" -> "engine__base" [style="solid",  color="#000000"];
        "instances__spells" -> "instances__effects" [style="solid",  color="#000000"];
        "instances__weapons" -> "engine__action" [style="solid",  color="#000000"];
        "instances__weapons" -> "engine__base" [style="solid",  color="#000000"];
        "instances__weapons" -> "engine__entity" [style="solid",  color="#000000"];
        "instances__weapons" -> "instances__effects" [style="solid",  color="#000000"];
        "test" -> "engine__action" [style="solid",  color="#000000"];
        "test" -> "engine__base" [style="solid",  color="#000000"];
        "test" -> "engine__encounter_manager" [style="solid",  color="#000000"];
        "test" -> "engine__entity" [style="solid",  color="#000000"];
        "test" -> "engine__game_manager" [style="solid",  color="#000000"];
        "test" -> "instances__effects" [style="solid",  color="#000000"];
        "test" -> "instances__entities" [style="solid",  color="#000000"];
        "test" -> "instances__others" [style="solid",  color="#000000"];
        "test" -> "instances__spells" [style="solid",  color="#000000"];
        "test" -> "instances__weapons" [style="solid",  color="#000000"];
    }
